@model List<EtatCivilGabon.Models.Demande>
@{
    ViewData["Title"] = "Toutes les demandes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">
            <i class="bi bi-folder2-open me-2 text-primary"></i>Toutes les demandes
        </h4>
        <small class="text-muted">@ViewBag.Total demande(s) au total</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Tableau de bord
        </a>
        <a asp-action="ExporterCsv" class="btn btn-outline-success btn-sm">
            <i class="bi bi-download me-1"></i>Export CSV
        </a>
    </div>
</div>

<!-- Filtres -->
<div class="card mb-3">
    <div class="card-body py-3">
        <form asp-action="Demandes" method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold small mb-1">Recherche</label>
                <input type="text" name="filtreRecherche" class="form-control form-control-sm"
                       placeholder="Numéro, nom, prénom..."
                       value="@ViewBag.FiltreRecherche" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small mb-1">Statut</label>
                <select name="filtreStatut" class="form-select form-select-sm">
                    <option value="">Tous les statuts</option>
                    <option value="EnAttente" selected="@(ViewBag.FiltreStatut == "EnAttente")">En attente</option>
                    <option value="EnCours"   selected="@(ViewBag.FiltreStatut == "EnCours")">En cours</option>
                    <option value="Pret"      selected="@(ViewBag.FiltreStatut == "Pret")">Prêt</option>
                    <option value="Rejete"    selected="@(ViewBag.FiltreStatut == "Rejete")">Rejeté</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small mb-1">Type d'acte</label>
                <select name="filtreTypeActe" class="form-select form-select-sm">
                    <option value="">Tous les types</option>
                    <option value="1" selected="@(ViewBag.FiltreTypeActe == "1")">Acte de naissance</option>
                    <option value="2" selected="@(ViewBag.FiltreTypeActe == "2")">Acte de mariage</option>
                    <option value="3" selected="@(ViewBag.FiltreTypeActe == "3")">Acte de décès</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel"></i> Filtrer
                </button>
                <a asp-action="Demandes" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Tableau -->
<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Résultats</h6>
        <span class="badge bg-secondary">@Model.Count résultat(s)</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-search fs-1 d-block mb-2"></i>
                Aucune demande ne correspond aux critères.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Numéro</th>
                            <th>Type d'acte</th>
                            <th>Demandeur</th>
                            <th>Date soumission</th>
                            <th>Mise à jour</th>
                            <th>Pièces</th>
                            <th>Statut</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model)
                        {
                            var (cls, txt, ico) = d.Statut switch
                            {
                                StatutDemande.EnAttente => ("badge-en-attente", "En attente", "bi-hourglass"),
                                StatutDemande.EnCours   => ("badge-en-cours",   "En cours",   "bi-arrow-repeat"),
                                StatutDemande.Pret      => ("badge-pret",       "Prêt",       "bi-check-circle"),
                                StatutDemande.Rejete    => ("badge-rejete",      "Rejeté",     "bi-x-circle"),
                                _                       => ("bg-secondary",      "-",          "bi-question")
                            };
                            <tr>
                                <td><span class="numero-suivi">@d.NumeroSuivi</span></td>
                                <td><small>@d.TypeActe?.Libelle</small></td>
                                <td><small>@d.PrenomDemandeur @d.NomDemandeur</small></td>
                                <td><small>@d.DateSoumission.ToString("dd/MM/yyyy")</small></td>
                                <td>
                                    <small class="text-muted">
                                        @(d.DateMiseAJour.HasValue
                                            ? d.DateMiseAJour.Value.ToString("dd/MM/yyyy")
                                            : "-")
                                    </small>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        @d.PiecesJointes.Count <i class="bi bi-paperclip"></i>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @cls">
                                        <i class="bi @ico me-1"></i>@txt
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Detail" asp-route-id="@d.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>Voir
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
