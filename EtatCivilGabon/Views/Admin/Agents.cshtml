@model GestionAgentsViewModel
@{
    ViewData["Title"] = "Gestion des agents";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">
            <i class="bi bi-people me-2 text-primary"></i>Gestion des agents
        </h4>
        <small class="text-muted">@Model.Agents.Count agent(s) enregistré(s)</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Tableau de bord
        </a>
        <a asp-action="CreerAgent" class="btn btn-primary btn-sm">
            <i class="bi bi-person-plus me-1"></i>Nouvel agent
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Agents.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1 d-block mb-2"></i>
                Aucun agent enregistré.
                <div class="mt-3">
                    <a asp-action="CreerAgent" class="btn btn-primary btn-sm">
                        Créer le premier agent
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Agent</th>
                            <th>Adresse e-mail</th>
                            <th>Date d'inscription</th>
                            <th>Statut</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var agent in Model.Agents)
                        {
                            var avatarBg = agent.EstActif ? "#003DA5" : "#6c757d";
                            var initiale = agent.NomComplet.Length > 0
                                ? agent.NomComplet.Substring(0, 1).ToUpper()
                                : "?";
                            var rowClass = agent.EstActif ? "" : "table-secondary";

                            <tr class="@rowClass">
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                                             style="width:36px;height:36px;background:@avatarBg;color:white;font-weight:bold;font-size:.85em;flex-shrink:0;">
                                            @initiale
                                        </div>
                                        <div>
                                            <div class="fw-semibold small">@agent.NomComplet</div>
                                            <div class="text-muted" style="font-size:.75rem;">Agent de mairie</div>
                                        </div>
                                    </div>
                                </td>
                                <td><small>@agent.Email</small></td>
                                <td><small>@agent.DateInscription.ToString("dd/MM/yyyy")</small></td>
                                <td>
                                    @if (agent.EstActif)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Actif
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="bi bi-slash-circle me-1"></i>Désactivé
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    @{
                                        var btnClass = agent.EstActif ? "btn-outline-danger" : "btn-outline-success";
                                        var btnIcon  = agent.EstActif ? "bi-slash-circle" : "bi-check-circle";
                                        var btnTxt   = agent.EstActif ? "Désactiver" : "Réactiver";
                                        var msgConfirm = agent.EstActif
                                            ? "Désactiver ce compte agent ?"
                                            : "Réactiver ce compte agent ?";
                                    }
                                    <form asp-action="BasculerStatutAgent" method="post"
                                          style="display:inline;"
                                          onsubmit="return confirm(this.dataset.msg)"
                                          data-msg="@msgConfirm">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@agent.Id" />
                                        <button type="submit" class="btn btn-sm @btnClass">
                                            <i class="bi @btnIcon me-1"></i>@btnTxt
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
