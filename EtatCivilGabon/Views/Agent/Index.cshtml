@model TableauDeBordAgentViewModel
@{
    ViewData["Title"] = "Tableau de bord — Agent";
}

<!-- En-tête -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">
            <i class="bi bi-clipboard-check me-2 text-success"></i>Espace Agent
        </h4>
        <small class="text-muted">Gestion et traitement des dossiers citoyens</small>
    </div>
</div>

<!-- Compteurs globaux -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <a asp-action="Index" asp-route-filtreStatut="EnAttente"
           class="text-decoration-none">
            <div class="card p-3 text-center border-start border-4 border-secondary h-100">
                <div class="fs-2 fw-bold text-secondary">@Model.TotalEnAttente</div>
                <small class="text-muted">En attente</small>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Index" asp-route-filtreStatut="EnCours"
           class="text-decoration-none">
            <div class="card p-3 text-center border-start border-4 border-warning h-100">
                <div class="fs-2 fw-bold text-warning">@Model.TotalEnCours</div>
                <small class="text-muted">En cours</small>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Index" asp-route-filtreStatut="Pret"
           class="text-decoration-none">
            <div class="card p-3 text-center border-start border-4 border-success h-100">
                <div class="fs-2 fw-bold text-success">@Model.TotalPret</div>
                <small class="text-muted">Prêt(s)</small>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Index" asp-route-filtreStatut="Rejete"
           class="text-decoration-none">
            <div class="card p-3 text-center border-start border-4 border-danger h-100">
                <div class="fs-2 fw-bold text-danger">@Model.TotalRejete</div>
                <small class="text-muted">Rejeté(s)</small>
            </div>
        </a>
    </div>
</div>

<!-- Filtres -->
<div class="card mb-3">
    <div class="card-body py-3">
        <form asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold small mb-1">Recherche</label>
                <input type="text" name="filtreRecherche" class="form-control form-control-sm"
                       placeholder="Numéro, nom, prénom..."
                       value="@Model.FiltreRecherche" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small mb-1">Statut</label>
                <select name="filtreStatut" class="form-select form-select-sm">
                    <option value="">Tous les statuts</option>
                    <option value="EnAttente" selected="@(Model.FiltreStatut == "EnAttente")">En attente</option>
                    <option value="EnCours"   selected="@(Model.FiltreStatut == "EnCours")">En cours</option>
                    <option value="Pret"      selected="@(Model.FiltreStatut == "Pret")">Prêt</option>
                    <option value="Rejete"    selected="@(Model.FiltreStatut == "Rejete")">Rejeté</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small mb-1">Type d'acte</label>
                <select name="filtreTypeActe" class="form-select form-select-sm">
                    <option value="">Tous les types</option>
                    <option value="1" selected="@(Model.FiltreTypeActe == "1")">Acte de naissance</option>
                    <option value="2" selected="@(Model.FiltreTypeActe == "2")">Acte de mariage</option>
                    <option value="3" selected="@(Model.FiltreTypeActe == "3")">Acte de décès</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-fill">
                    <i class="bi bi-funnel"></i> Filtrer
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Liste des dossiers -->
<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-bold">
            <i class="bi bi-folder2-open me-2"></i>Dossiers
        </h6>
        <span class="badge bg-secondary">@Model.Demandes.Count résultat(s)</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Demandes.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                Aucun dossier ne correspond aux critères sélectionnés.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Numéro</th>
                            <th>Type d'acte</th>
                            <th>Demandeur</th>
                            <th>Date soumission</th>
                            <th>Statut</th>
                            <th>Pièces</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Demandes)
                        {
                            var (cls, txt, ico) = d.Statut switch
                            {
                                StatutDemande.EnAttente => ("badge-en-attente", "En attente", "bi-hourglass"),
                                StatutDemande.EnCours   => ("badge-en-cours",   "En cours",   "bi-arrow-repeat"),
                                StatutDemande.Pret      => ("badge-pret",       "Prêt",       "bi-check-circle"),
                                StatutDemande.Rejete    => ("badge-rejete",      "Rejeté",     "bi-x-circle"),
                                _                       => ("bg-secondary",      "-",          "bi-question")
                            };
                            <tr>
                                <td><span class="numero-suivi">@d.NumeroSuivi</span></td>
                                <td><small>@d.TypeActe?.Libelle</small></td>
                                <td><small>@d.PrenomDemandeur @d.NomDemandeur</small></td>
                                <td><small>@d.DateSoumission.ToString("dd/MM/yyyy")</small></td>
                                <td>
                                    <span class="badge @cls">
                                        <i class="bi @ico me-1"></i>@txt
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        @d.PiecesJointes.Count <i class="bi bi-paperclip"></i>
                                    </span>
                                </td>
                                <td class="text-end">
                                    @if (d.Statut == StatutDemande.Pret || d.Statut == StatutDemande.Rejete)
                                    {
                                        <a asp-action="Consulter" asp-route-id="@d.Id"
                                           class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye me-1"></i>Voir
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="Traiter" asp-route-id="@d.Id"
                                           class="btn btn-sm btn-primary">
                                            <i class="bi bi-pencil-square me-1"></i>Traiter
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
