@using EtatCivilGabon.Models
@model IEnumerable<PieceJointe>

@if (Model != null && Model.Any())
{
    <div class="card">
        <div class="card-header bg-white fw-semibold py-3">
            <i class="bi bi-paperclip me-2 text-primary"></i>
            Pièces justificatives (@Model.Count())
        </div>
        <ul class="list-group list-group-flush">
            @foreach (var p in Model)
            {
                var estPdf   = p.TypeMime?.Contains("pdf") == true
                               || p.NomFichier.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
                var estImage = p.TypeMime?.Contains("image") == true
                               || p.NomFichier.EndsWith(".jpg",  StringComparison.OrdinalIgnoreCase)
                               || p.NomFichier.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
                               || p.NomFichier.EndsWith(".png",  StringComparison.OrdinalIgnoreCase);

                var icone = estPdf   ? "bi-file-pdf text-danger"
                          : estImage ? "bi-file-image text-primary"
                          :            "bi-file-earmark text-secondary";

                var taille = p.Taille < 1024
                    ? $"{p.Taille} o"
                    : p.Taille < 1024 * 1024
                        ? $"{(p.Taille / 1024.0):0.0} Ko"
                        : $"{(p.Taille / (1024.0 * 1024)):0.0} Mo";

                <li class="list-group-item px-3 py-2">
                    <div class="d-flex align-items-center gap-3 flex-wrap">

                        <!-- Icône + nom -->
                        <i class="bi @icone fs-5 flex-shrink-0"></i>
                        <div class="flex-grow-1 min-width-0">
                            <div class="fw-semibold small text-truncate" title="@p.NomFichier">
                                @p.NomFichier
                            </div>
                            <div class="text-muted" style="font-size:.75rem;">
                                @taille &nbsp;·&nbsp; @p.DateDepot.ToString("dd/MM/yyyy à HH:mm")
                            </div>
                        </div>

                        <!-- Boutons action -->
                        <div class="d-flex gap-2 flex-shrink-0">

                            @if (estPdf || estImage)
                            {
                                <!-- Bouton Visualiser (ouvre dans un nouvel onglet) -->
                                <a href="@Url.Action("Voir", "Fichier", new { id = p.Id })"
                                   target="_blank"
                                   class="btn btn-sm btn-outline-primary"
                                   title="Visualiser dans le navigateur">
                                    <i class="bi bi-eye me-1"></i>Visualiser
                                </a>
                            }

                            <!-- Bouton Télécharger -->
                            <a href="@Url.Action("Telecharger", "Fichier", new { id = p.Id })"
                               class="btn btn-sm btn-outline-secondary"
                               title="Télécharger le fichier">
                                <i class="bi bi-download me-1"></i>Télécharger
                            </a>

                        </div>
                    </div>

                    @* Prévisualisation image inline (optionnel) *@
                    @if (estImage)
                    {
                        <div class="mt-2">
                            <img src="@Url.Action("Voir", "Fichier", new { id = p.Id })"
                                 alt="@p.NomFichier"
                                 class="img-thumbnail"
                                 style="max-height:150px; max-width:250px; object-fit:contain; cursor:pointer;"
                                 onclick="ouvrirModal('@Url.Action("Voir", "Fichier", new { id = p.Id })', '@p.NomFichier')"
                                 title="Cliquer pour agrandir" />
                        </div>
                    }
                </li>
            }
        </ul>
    </div>

    <!-- Modal agrandissement image -->
    <div class="modal fade" id="modalImage" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title mb-0" id="modalImageTitre"></h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-2">
                    <img id="modalImageSrc" src="" alt=""
                         class="img-fluid rounded" style="max-height:75vh;" />
                </div>
                <div class="modal-footer py-2">
                    <a id="modalImageLien" href="#" target="_blank"
                       class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-arrows-fullscreen me-1"></i>Ouvrir en plein écran
                    </a>
                    <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function ouvrirModal(url, nom) {
            document.getElementById('modalImageSrc').src   = url;
            document.getElementById('modalImageTitre').textContent = nom;
            document.getElementById('modalImageLien').href = url;
            new bootstrap.Modal(document.getElementById('modalImage')).show();
        }
    </script>
}
else
{
    <div class="card">
        <div class="card-header bg-white fw-semibold py-3">
            <i class="bi bi-paperclip me-2 text-primary"></i>Pièces justificatives
        </div>
        <div class="card-body text-muted small">
            <i class="bi bi-info-circle me-2"></i>Aucune pièce jointe déposée pour cette demande.
        </div>
    </div>
}
