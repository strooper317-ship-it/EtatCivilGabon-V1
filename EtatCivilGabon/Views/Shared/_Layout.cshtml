<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — État Civil Gabon</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        :root {
            --gabon-vert:  #009E60;
            --gabon-jaune: #FCD116;
            --gabon-bleu:  #003DA5;
        }
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }

        .navbar-brand span.vert   { color: var(--gabon-vert); }
        .navbar-brand span.jaune  { color: var(--gabon-jaune); }
        .navbar-brand span.bleu   { color: var(--gabon-bleu); }

        .navbar { background-color: #1a2c4e; }
        .navbar .nav-link, .navbar-brand { color: #fff !important; }
        .navbar .nav-link:hover { color: var(--gabon-jaune) !important; }

        .bandeau-gabon {
            height: 5px;
            background: linear-gradient(to right,
                var(--gabon-vert) 33.3%,
                var(--gabon-jaune) 33.3% 66.6%,
                var(--gabon-bleu) 66.6%);
        }

        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); border-radius: 10px; }
        .btn-primary { background-color: var(--gabon-bleu); border-color: var(--gabon-bleu); }
        .btn-primary:hover { background-color: #002d80; border-color: #002d80; }
        .btn-success { background-color: var(--gabon-vert); border-color: var(--gabon-vert); }

        footer { background-color: #1a2c4e; color: #adb5bd; }
    </style>
</head>
<body>

<div class="bandeau-gabon"></div>

<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand fw-bold fs-5" asp-controller="Home" asp-action="Index">
            <i class="bi bi-building me-2"></i>
            <span class="vert">État</span><span class="jaune">Civil</span><span class="bleu">Gabon</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto align-items-center gap-2">

                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Citoyen"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Citoyen" asp-action="Index">
                                <i class="bi bi-house"></i> Mon espace
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Citoyen" asp-action="NouvelleDemande">
                                <i class="bi bi-plus-circle"></i> Nouvelle demande
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Agent"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Agent" asp-action="Index">
                                <i class="bi bi-clipboard-check"></i> Dossiers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Agent" asp-route-filtreStatut="EnAttente"
                               asp-action="Index">
                                <i class="bi bi-hourglass"></i> En attente
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Administrateur"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Tableau de bord
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Agents">
                                <i class="bi bi-people"></i> Agents
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Demandes">
                                <i class="bi bi-folder2-open"></i> Dossiers
                            </a>
                        </li>
                    }

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" asp-controller="Compte" asp-action="ChangerMotDePasse">
                                    <i class="bi bi-key me-2"></i>Changer le mot de passe
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Compte" asp-action="Deconnexion" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Se déconnecter
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                <li class="nav-item">
                        <a class="nav-link" asp-controller="Citoyen" asp-action="Suivi">
                            <i class="bi bi-search"></i> Suivre une demande
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Compte" asp-action="Connexion">
                            <i class="bi bi-box-arrow-in-right"></i> Connexion
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-warning text-dark fw-bold ms-2"
                           asp-controller="Compte" asp-action="Inscription">
                            <i class="bi bi-person-plus"></i> S'inscrire
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container py-4">

    @* Alertes globales *@
    @if (TempData["Succes"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Erreur"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Erreur"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</main>

<footer class="py-3 mt-5">
    <div class="container text-center small">
        <p class="mb-0">
            © @DateTime.Now.Year — Plateforme État Civil Gabon &nbsp;|&nbsp;
            Tous droits réservés &nbsp;|&nbsp;
            <a href="#" class="text-secondary">Contact</a>
        </p>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
