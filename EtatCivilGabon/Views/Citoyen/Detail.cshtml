@model DetailDemandeViewModel
@{
    ViewData["Title"] = "Détail de la demande";
    var (clsBadge, txtStatut, icoStatut) = Model.Statut switch
    {
        StatutDemande.EnAttente => ("badge-en-attente", "En attente", "bi-hourglass"),
        StatutDemande.EnCours   => ("badge-en-cours",   "En cours",   "bi-arrow-repeat"),
        StatutDemande.Pret      => ("badge-pret",       "Prêt",       "bi-check-circle"),
        StatutDemande.Rejete    => ("badge-rejete",      "Rejeté",     "bi-x-circle"),
        _                       => ("bg-secondary",      "Inconnu",    "bi-question")
    };
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0">Détail de la demande</h4>
        <small class="text-muted">@Model.TypeActeLibelle</small>
    </div>
</div>

<div class="row g-4">
    <!-- Colonne principale -->
    <div class="col-lg-8">

        <!-- Numéro et statut -->
        <div class="card mb-4">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <div class="text-muted small mb-1">Numéro de suivi</div>
                    <span class="numero-suivi fs-5">@Model.NumeroSuivi</span>
                </div>
                <span class="badge @clsBadge fs-6 px-3 py-2">
                    <i class="bi @icoStatut me-2"></i>@txtStatut
                </span>
            </div>
        </div>

        <!-- Document final disponible (si statut Prêt) -->
        @if (Model.Statut == StatutDemande.Pret && !string.IsNullOrEmpty(Model.NomDocumentFinal))
        {
            <div class="card mb-4 border-2 border-success">
                <div class="card-header py-3"
                     style="background:linear-gradient(135deg,#009E60,#00b368); color:white;">
                    <i class="bi bi-file-check fs-5 me-2"></i>
                    <strong>Votre document est disponible !</strong>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <div class="rounded-circle d-flex align-items-center justify-content-center"
                             style="width:50px;height:50px;background:#f0fff4;flex-shrink:0;">
                            <i class="bi bi-file-earmark-check text-success fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@Model.NomDocumentFinal</div>
                            @if (Model.DateEnvoiDocument.HasValue)
                            {
                                <small class="text-muted">
                                    Disponible depuis le
                                    @Model.DateEnvoiDocument.Value.ToString("dd/MM/yyyy à HH:mm")
                                </small>
                            }
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a href="@Url.Action("VoirDocumentFinal", "Fichier", new { demandeId = Model.Id })"
                               target="_blank"
                               class="btn btn-success">
                                <i class="bi bi-eye me-2"></i>Visualiser
                            </a>
                            <a href="@Url.Action("TelechargerDocumentFinal", "Fichier", new { demandeId = Model.Id })"
                               class="btn btn-outline-success">
                                <i class="bi bi-download me-2"></i>Télécharger
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Informations de la demande -->
        <div class="card mb-4">
            <div class="card-header bg-white fw-semibold py-3">
                <i class="bi bi-info-circle me-2 text-primary"></i>Informations
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="text-muted small">Type d'acte</div>
                        <div class="fw-semibold">@Model.TypeActeLibelle</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small">Demandeur</div>
                        <div class="fw-semibold">@Model.PrenomDemandeur @Model.NomDemandeur</div>
                    </div>
                    <div class="col-12">
                        <div class="text-muted small">Objet de la demande</div>
                        <div>@Model.ObjetDemande</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small">Date de soumission</div>
                        <div>@Model.DateSoumission.ToString("dd/MM/yyyy à HH:mm")</div>
                    </div>
                    @if (Model.DateMiseAJour.HasValue)
                    {
                        <div class="col-md-6">
                            <div class="text-muted small">Dernière mise à jour</div>
                            <div>@Model.DateMiseAJour.Value.ToString("dd/MM/yyyy à HH:mm")</div>
                        </div>
                    }
                    <div class="col-md-6">
                        <div class="text-muted small">Délai cible</div>
                        <div>@Model.DelaiCible jours ouvrés</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Commentaire agent -->
        @if (!string.IsNullOrEmpty(Model.CommentaireAgent))
        {
            <div class="card mb-4 border-start border-4
                @(Model.Statut == StatutDemande.Rejete ? "border-danger" : "border-success")">
                <div class="card-body">
                    <div class="fw-semibold mb-1">
                        <i class="bi bi-chat-left-text me-2"></i>Message de l'agent
                    </div>
                    <p class="mb-0">@Model.CommentaireAgent</p>
                </div>
            </div>
        }

        <!-- Pièces jointes déposées par le citoyen -->
        <partial name="_PiecesJointes" model="Model.PiecesJointes" />

    </div>

    <!-- Colonne latérale : timeline -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-white fw-semibold py-3">
                <i class="bi bi-activity me-2 text-primary"></i>Progression
            </div>
            <div class="card-body">
                @{
                    var etapes = new[]
                    {
                        (StatutDemande.EnAttente, "Demande soumise",     "bi-send"),
                        (StatutDemande.EnCours,   "Traitement en cours", "bi-gear"),
                        (StatutDemande.Pret,      "Document prêt",       "bi-check-circle"),
                    };
                    var ordreStatut = new Dictionary<StatutDemande, int>
                    {
                        [StatutDemande.EnAttente] = 0,
                        [StatutDemande.EnCours]   = 1,
                        [StatutDemande.Pret]      = 2,
                        [StatutDemande.Rejete]    = -1,
                    };
                    int niveauActuel = ordreStatut.GetValueOrDefault(Model.Statut, 0);
                }

                @if (Model.Statut == StatutDemande.Rejete)
                {
                    <div class="text-center text-danger py-3">
                        <i class="bi bi-x-circle fs-2 d-block mb-2"></i>
                        <strong>Demande rejetée</strong>
                        <div class="small text-muted mt-1">Consultez le message de l'agent.</div>
                    </div>
                }
                else
                {
                    <ul class="timeline">
                        @foreach (var (statut, label, icone) in etapes)
                        {
                            int niveauEtape = ordreStatut[statut];
                            bool estActif   = niveauEtape <= niveauActuel;
                            bool estCourant = niveauEtape == niveauActuel;

                            <li>
                                <div class="timeline-dot @(estActif ? "actif" : "inactif")"></div>
                                <div>
                                    <div class="@(estCourant ? "fw-bold" : estActif ? "text-success" : "text-muted") small">
                                        <i class="bi @icone me-1"></i>@label
                                    </div>
                                    @if (estCourant)
                                    {
                                        <div class="text-muted" style="font-size:.75rem;">Étape actuelle</div>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
