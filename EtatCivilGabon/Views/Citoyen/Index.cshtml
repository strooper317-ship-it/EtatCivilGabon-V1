@model MesDemandesViewModel
@{
    ViewData["Title"] = "Mon espace";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">
            <i class="bi bi-person-circle me-2 text-primary"></i>
            Bonjour, @ViewBag.NomComplet
        </h4>
        <small class="text-muted">Gérez vos demandes d'actes d'état civil</small>
    </div>
    <a asp-action="NouvelleDemande" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Nouvelle demande
    </a>
</div>

<!-- Statistiques rapides -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card p-3 text-center border-start border-4 border-secondary">
            <div class="fs-2 fw-bold text-secondary">@Model.TotalEnAttente</div>
            <small class="text-muted">En attente</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card p-3 text-center border-start border-4 border-warning">
            <div class="fs-2 fw-bold text-warning">@Model.TotalEnCours</div>
            <small class="text-muted">En cours</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card p-3 text-center border-start border-4 border-success">
            <div class="fs-2 fw-bold text-success">@Model.TotalPret</div>
            <small class="text-muted">Prêt(s)</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card p-3 text-center border-start border-4 border-danger">
            <div class="fs-2 fw-bold text-danger">@Model.TotalRejete</div>
            <small class="text-muted">Rejeté(s)</small>
        </div>
    </div>
</div>

<!-- Liste des demandes -->
<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Mes demandes</h6>
        <span class="badge bg-secondary">@Model.Demandes.Count au total</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Demandes.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                Aucune demande pour l'instant.
                <div class="mt-3">
                    <a asp-action="NouvelleDemande" class="btn btn-primary btn-sm">
                        Soumettre ma première demande
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Numéro de suivi</th>
                            <th>Type d'acte</th>
                            <th>Date de soumission</th>
                            <th>Statut</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Demandes)
                        {
                            <tr>
                                <td><span class="numero-suivi">@d.NumeroSuivi</span></td>
                                <td>@d.TypeActe?.Libelle</td>
                                <td>@d.DateSoumission.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @{
                                        var (cls, txt, ico) = d.Statut switch
                                        {
                                            StatutDemande.EnAttente => ("badge-en-attente", "En attente", "bi-hourglass"),
                                            StatutDemande.EnCours   => ("badge-en-cours",   "En cours",   "bi-arrow-repeat"),
                                            StatutDemande.Pret      => ("badge-pret",       "Prêt",       "bi-check-circle"),
                                            StatutDemande.Rejete    => ("badge-rejete",      "Rejeté",     "bi-x-circle"),
                                            _                       => ("bg-secondary",      "Inconnu",    "bi-question")
                                        };
                                    }
                                    <span class="badge @cls">
                                        <i class="bi @ico me-1"></i>@txt
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Detail" asp-route-id="@d.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>Voir
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
